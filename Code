##pearsons correlation##

x=df['Life expectancy at birth (years)']
y=df['GDP']
corr, p_value=stats.pearsonr(x,y)

print(corr)
print(p_value)


##creating scattoerplots##
sns.scatterplot(x=x,y=y,hue='Country', data=df)

df['log_gdp']=np.log(df['GDP'])
